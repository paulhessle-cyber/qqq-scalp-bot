# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it's in .gitignore.

# ── Telegram ────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Interactive Brokers ──────────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497          # 7497 = paper trading | 7496 = live trading
IB_CLIENT_ID=10

# ── Strategy ─────────────────────────────────────────────────────────────────
TICKER=QQQ
POSITION_SIZE_SHARES=10        # How many shares per trade
MAX_RISK_PER_TRADE_USD=100     # Max dollar risk per trade (stop placement guard)
